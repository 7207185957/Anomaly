# ============================================
# Frontend
# ============================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:9001/api/v1
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_DEMO_USERNAME=demo
NEXT_PUBLIC_DEMO_PASSWORD=demo123
FRONTEND_HOST_PORT=3000
BACKEND_HOST_PORT=9001

# ============================================
# Backend
# ============================================
APP_NAME=Enterprise AIOps API
ENVIRONMENT=development
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=change-me
PG_DB=postgres

LOKI_URL=http://localhost:3100/loki/api/v1/query_range
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT=wcs-dataops-mlflow/dataops/infra-anomalies
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# LDAP (provided details - keep password in secrets manager / env injection)
LDAP_SERVER=ldap://dwad.prod.aws.amazon.net
LDAP_PORT=389
# Use unquoted booleans in .env (false/true, not "false"/"true")
LDAP_USE_SSL=false
LDAP_USE_TLS=false
LDAP_BASE_DN=OU=aws,OU=dwad,DC=dwad,DC=prod,DC=aws,DC=amazon,DC=net
LDAP_BIND_DN=CN=svc_jupiter,OU=Service Accounts,OU=aws,OU=dwad,DC=dwad,DC=prod,DC=aws,DC=amazon,DC=net
LDAP_BIND_PASSWORD=change-me
LDAP_AUTH_UID=sAMAccountName
LDAP_GROUP_ATTRIBUTE=memberOf
LDAP_ADMIN_GROUP_KEYWORD=Admins

REDIS_URL=redis://localhost:6379/0
RCA_QUEUE_NAME=rca-jobs

NEBULA_HOST=127.0.0.1
NEBULA_PORT=9669
NEBULA_USER=root
NEBULA_PASSWORD=nebula
NEBULA_SPACE=inventory_tracking
NEBULA_EDGE_LIMIT=5000

# ============================================
# Demo mode
# ============================================
DEMO_MODE=true
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123
DEMO_DISPLAY_NAME=AIOps Demo User
DEMO_GROUPS=["AIOps-Demo","Admins"]

